---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Teaching" sideBarActiveItemID="services">
  <div class="mb-8">
    <h1 class="text-4xl font-bold">Teaching & Academic Impact</h1>
    <p class="mt-2 text-gray-600 max-w-xl">
      Engaging students through core courses, targeted guest lectures, and hands‑on project mentorship.
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <!-- Data Structures (no description, so we still pass an empty one) -->
    <HorizontalCard
      title="CSE 2383 – Data Structures & Algorithm Analysis"
      img="/assets/icons/data-structures.svg"
      url="#"
      desc=""
      tags={['Spring 2023','Fall 2023','Spring 2024','Fall 2024','Spring 2025']}
    />

    <!-- Remote Sensing Seminar (with real description) -->
    <HorizontalCard
      title="PSS 4411/6411 – Remote Sensing Seminar"
      img="/assets/icons/remote-sensing.svg"
      url="#"
      desc="Delivered seminars on integrating autonomous systems with field data collection, covering LiDAR mapping, ecological modeling, and vehicle applications."
      tags={['Fall 2022','Fall 2023','Fall 2024']}
    />

    <!-- HCI Projects (also needs desc even though blank) -->
    <HorizontalCard
      title="CSE 4663 – Human‑Computer Interaction Projects"
      img="/assets/icons/hci.svg"
      url="#"
      desc=""
      tags={['Fall 2024']}
    />
  </div>
</BaseLayout>
