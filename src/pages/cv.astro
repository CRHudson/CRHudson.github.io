---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  {/* Profile Section */}
  <div class="mb-5">
    <div class="text-3xl font-bold">Profile</div>
  </div>
  <div class="mb-10 text-justify">
    I am a Senior Research Engineer at the Center for Advanced Vehicular Systems (CAVS) and a Lecturer in the Department of Computer Science and Engineering at Mississippi State University. I earned a Ph.D. in Computer Science, a B.S. in Computer Science from UNC Pembroke, and an MBA with a focus on Project Management. My research advances off‑road autonomous systems, multi‑agent robotics, and precision field robotics for agricultural and defense applications. I integrate ecological simulation, machine learning, and AI to improve autonomous navigation and enhance system deployment in complex environments.
  </div>

  {/* Education Section */}
  <div class="mb-5">
    <div class="text-3xl font-bold">Education</div>
  </div>
  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement title="Masters of Instructional Technology" subtitle="2025 - Estimated Completion: December 2027 at Mississippi State University" />
    <TimeLineElement title="Masters of Business Administration - Project Management" subtitle="2022 - 2024 at Mississippi State University" />
    <TimeLineElement title="Doctor of Philosophy, Computer Science" subtitle="2014 - 2022 at Mississippi State University" />
    <TimeLineElement title="Bachelor's Degree, Computer Science" subtitle="2010 - 2014 at University of North Carolina at Pembroke" />
  </div>

  {/* Experience Section */}
  <div class="mb-5">
    <div class="text-3xl font-bold">Experience</div>
  </div>
  <div class="time-line-container mb-10">
    <TimeLineElement title="Lecturer" subtitle="2022 - Present at CSE, Mississippi State University" />
    <TimeLineElement title="Senior Research Engineer" subtitle="2025 - Present at CAVS, Mississippi State University" />
    <TimeLineElement title="Research Engineer III" subtitle="2022 - 2025 at CAVS, Mississippi State University" />
    <TimeLineElement title="Research Engineer II" subtitle="2020 - 2022 at CAVS, Mississippi State University" />
    <TimeLineElement title="Research Engineer I" subtitle="2017 - 2020 at CAVS, Mississippi State University" />
    <TimeLineElement title="Graduate Research Assistant" subtitle="2014 - 2017 at CAVS, Mississippi State University" />
  </div>

  {/* Publications Link */}
  <div class="mb-10">
    <a
      href="/publications"
      class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded"
    >
      View Publications →
    </a>
  </div>

  {/* Skills Section */}
  <div class="mb-5">
    <div class="text-3xl font-bold">Skills</div>
  </div>
  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>C++</li>
    <li>C#/.NET</li>
    <li>Python</li>
    <li>Java</li>
    <li>SQL </li>
    <li>Robotics</li>
    <li>Autonomous Systems</li>
    <li>Virtual Reality</li>
    <li>AI and Machine Learning</li>
    <li>Simulation</li>
    <li>Vehicle Mobility Analysis</li>
    <li>ROS/ROS2</li>
    <li>Computer Vision</li>
    <li>Human-Computer Interaction</li>
    <li>Teaching and Mentoring</li>
  </ul>
</BaseLayout>
