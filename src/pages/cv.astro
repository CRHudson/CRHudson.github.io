---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Senior Research Engineer at the Center for Advanced Vehicular Systems (CAVS) at Mississippi State University specializing in off-road autonomous systems. Holds a B.S. in Computer Science from UNC Pembroke and a Ph.D. in Computer Science. Focused on modeling, simulation, and real-world testing to enhance ground vehicle mobility forecasting. Additional experience includes VR applications, immersive training systems, and human-computer interaction studies. Active educator and mentor in Computer Science.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Masters of BInstructional Technology"
      subtitle="2025 - Estimated Completion: December 2027 at Mississippi State University"
    />
    <TimeLineElement
      title="Masters of Business Administration - Project Management"
      subtitle="2022 - 2024 at Mississippi State University"
    />
    <TimeLineElement
      title="Doctor of Philosophy, Computer Science"
      subtitle="2014 - 2022 at Mississippi State University"
    />
    <TimeLineElement
      title="Bachelor's Degree, Computer Science"
      subtitle="2010 - 2014 at University of North Carolina at Pembroke"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Lecturer"
      subtitle="2022 - Present at CSE, Mississippi State University"
    />
    <TimeLineElement
      title="Senior Research Engineer"
      subtitle="2025 - Present at CAVS, Mississippi State University"
    />
    <TimeLineElement
      title="Research Engineer III"
      subtitle="2022 - 2025 at CAVS, Mississippi State University"
    />
    <TimeLineElement
      title="Research Engineer II"
      subtitle="2020 - 2022 at CAVS, Mississippi State University"
    />
    <TimeLineElement
      title="Research Engineer I"
      subtitle="2017 - 2020 at CAVS, Mississippi State University"
    />
    <TimeLineElement
      title="Graduate Research Assistant"
      subtitle="2014 - 2017 at CAVS, Mississippi State University"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>
      <a href="#" target="_blank">Advanced Vehicle Systems Research Certification (Placeholder - Add Link)</a>
    </li>
    <li>
      <a href="#" target="_blank">Human-Computer Interaction Specialist Certification (Placeholder - Add Link)</a>
    </li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>C++</li>
    <li>C#/.NET</li>
    <li>Python</li>
    <li>Java</li>
    <li>SQL</li>
    <li>Robotics</li>
    <li>Autonomous Systems</li>
    <li>Virtual Reality</li>
    <li>AI and Machine Learning</li>
    <li>Simulation</li>
    <li>Vehicle Mobility Analysis</li>
    <li>ROS/ROS2</li>
    <li>Computer Vision</li>
    <li>Human-Computer Interaction</li>
    <li>Teaching and Mentoring</li>
  </ul>
</BaseLayout>
