---
// src/components/cv/PublicationCard.astro
const { publication } = Astro.props;
---

{publication.pdfUrl && publication.pdfUrl.trim() !== '' ? (
  <a
    href={publication.pdfUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="block bg-white border border-gray-200 rounded-lg p-4 shadow-sm hover:shadow-lg hover:border-gray-300 hover:bg-gray-100 transition cursor-pointer"
  >
    <h3 class="text-xl font-semibold text-gray-900 mb-1">
      {publication.title}
    </h3>
    <p class="text-sm text-gray-700 mb-1">
      {publication.venue}{publication.year ? ` (${publication.year})` : ""}
    </p>
    <p class="text-base text-gray-800">
      Authors: <span class="font-medium">{publication.authors}</span>
    </p>
  </a>
) : (
  <div
    class="block bg-white border border-gray-200 rounded-lg p-4 shadow-sm transition cursor-default"
  >
    <h3 class="text-xl font-semibold text-gray-900 mb-1">
      {publication.title}
    </h3>
    <p class="text-sm text-gray-700 mb-1">
      {publication.venue}{publication.year ? ` (${publication.year})` : ""}
    </p>
    <p class="text-base text-gray-800">
      Authors: <span class="font-medium">{publication.authors}</span>
    </p>
  </div>
)}