---
// src/components/cv/PublicationCard.astro
const { publication } = Astro.props;
---

<a
  href={publication.scholarUrl}
  target="_blank"
  class="block bg-gray-50 border border-gray-200 rounded-lg p-6 shadow-sm hover:shadow-lg transition cursor-pointer min-h-[200px]"
>
  <h3 class="text-xl font-semibold text-gray-900 mb-2">
    {publication.title}
  </h3>
  <p class="text-sm text-gray-700 mb-1">
    {publication.venue}{publication.year ? ` (${publication.year})` : ""}
  </p>
  <p class="text-base text-gray-800">
    Authors: <span class="font-medium">{publication.authors}</span>
  </p>
</a>
